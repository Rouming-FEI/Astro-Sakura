---
import { getCollection, render } from 'astro:content';
import PostLayout from '../../../layouts/PostLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => !data.draft);
  return posts.map(post => ({
    params: { lang: post.data.lang, slug: post.id },
  }));
}

const { slug, lang } = Astro.params;
const posts = await getCollection('posts', ({ data }) => !data.draft && data.lang === lang);
const post = posts.find(p => p.id === slug);

if (!post) return Astro.redirect(`/${lang}/`);

const { Content, headings } = await render(post);

const relatedPosts = posts
  .filter(p => p.id !== slug)
  .filter(p => p.data.tags?.some(t => post.data.tags?.includes(t)))
  .slice(0, 3)
  .map(p => ({
    title: p.data.title,
    slug: p.id,
    excerpt: p.data.excerpt,
  }));
---

<PostLayout
  title={post.data.title}
  date={post.data.date}
  {lang}
  description={post.data.excerpt}
  ogImage={post.data.thumbnail}
  category={post.data.category}
  tags={post.data.tags}
  {headings}
  {relatedPosts}
>
  <Content />
</PostLayout>
