---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../config/site';
import zh from '../i18n/zh';

if (!siteConfig.features.steam) {
  return Astro.redirect('/', 302);
}

const isConfigured = Boolean(siteConfig.steam.apiKey && siteConfig.steam.steamId);
---

<BaseLayout title={zh.steam}>
  <div class="custom-page">
    {
      isConfigured ? (
        <div id="steam-grid-root">
          <!-- Skeleton loading state -->
          <div class="steam-grid" id="steam-grid">
            {Array.from({ length: 8 }).map(() => (
              <div class="game-card skeleton">
                <div class="card-image-wrap">
                  <div class="skeleton-img"></div>
                </div>
                <div class="card-info">
                  <div class="skeleton-line skeleton-name"></div>
                  <div class="skeleton-line skeleton-stat"></div>
                </div>
              </div>
            ))}
          </div>
          <p class="steam-counter" id="steam-counter"></p>
        </div>
      ) : (
        <div class="placeholder-hero">
          <div class="placeholder-icon">
            <svg width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" opacity="0.3">
              <circle cx="12" cy="12" r="10"/>
              <path d="M8 12l2 2 4-4"/>
              <line x1="14" y1="8" x2="18" y2="4"/>
              <polygon points="6,2 18,2 20,6 18,6 16,4 8,4 6,6 4,6"/>
            </svg>
          </div>
          <h1>{zh.steam}</h1>
          <p class="placeholder-desc">游戏收藏展示 — 游戏时长、成就、评测</p>
          <div class="placeholder-badge">即将上线</div>

          <div class="config-instructions">
            <h2>配置 Steam API</h2>
            <ol>
              <li>
                前往
                <a href="https://steamcommunity.com/dev/apikey" target="_blank" rel="noopener noreferrer">
                  https://steamcommunity.com/dev/apikey
                </a>
                获取您的 Steam Web API Key
              </li>
              <li>获取您的 Steam 64 位 ID（可在 Steam 客户端「账户详情」或个人资料 URL 中找到）</li>
              <li>
                在 <code>src/config/site.ts</code> 中填入：
                <pre><code>steam: {'{'}{'\n'}  apiKey: 'YOUR_API_KEY',{'\n'}  steamId: 'YOUR_STEAM_ID_64',{'\n'}{'}'}</code></pre>
              </li>
            </ol>
          </div>
        </div>
      )
    }
  </div>
</BaseLayout>

<style>
  .custom-page {
    max-width: 1000px;
    margin: 80px auto 0;
    padding: 0 20px 60px;
  }

  /* ===== Placeholder ===== */
  .placeholder-hero {
    text-align: center;
    padding: 80px 20px 40px;
  }

  .placeholder-icon {
    margin-bottom: 20px;
    color: var(--primary);
  }

  .placeholder-hero h1 {
    font-size: 2rem;
    margin: 0 0 8px;
  }

  .placeholder-desc {
    color: var(--text-muted);
    font-size: 1rem;
    margin: 0 0 20px;
    line-height: 1.6;
  }

  .placeholder-badge {
    display: inline-block;
    font-size: 0.8rem;
    color: var(--primary);
    background: rgba(117, 149, 232, 0.1);
    padding: 4px 16px;
    border-radius: 20px;
    font-weight: 600;
    letter-spacing: 0.05em;
  }

  .config-instructions {
    margin-top: 48px;
    text-align: left;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 32px;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
    box-shadow: var(--shadow);
  }

  .config-instructions h2 {
    font-size: 1.15rem;
    margin: 0 0 16px;
    color: var(--primary);
  }

  .config-instructions ol {
    margin: 0;
    padding-left: 20px;
    color: var(--text);
    line-height: 1.8;
    font-size: 0.95rem;
  }

  .config-instructions li {
    margin-bottom: 12px;
  }

  .config-instructions a {
    word-break: break-all;
  }

  .config-instructions code {
    background: var(--accent);
    padding: 1px 6px;
    border-radius: 3px;
    font-family: var(--font-mono);
    font-size: 0.82rem;
  }

  .config-instructions pre {
    margin: 8px 0 0;
    background: var(--accent);
    border-radius: 6px;
    padding: 14px 16px;
    overflow-x: auto;
  }

  .config-instructions pre code {
    background: none;
    padding: 0;
    font-size: 0.78rem;
    line-height: 1.7;
  }

  /* ===== Card Grid ===== */
  .steam-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 20px;
  }

  /* ===== Game Card ===== */
  .game-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: var(--shadow);
    transition: transform 0.25s ease, box-shadow 0.25s ease;
    cursor: default;
  }

  .game-card:not(.skeleton):hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(56, 51, 96, 0.14);
  }

  html.dark .game-card:not(.skeleton):hover {
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.4);
  }

  .game-card.skeleton {
    pointer-events: none;
  }

  .card-image-wrap {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--accent);
  }

  .card-image-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.35s ease;
  }

  .game-card:not(.skeleton):hover .card-image-wrap img {
    transform: scale(1.06);
  }

  .card-image-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 24px 12px 8px;
    background: linear-gradient(transparent, rgba(0, 0, 0, 0.65));
  }

  .card-image-overlay .game-name {
    color: #fff;
    font-size: 0.9rem;
    font-weight: 600;
    line-height: 1.3;
    text-shadow: 0 1px 3px rgba(0, 0, 0, 0.5);
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }

  /* ===== Card Info ===== */
  .card-info {
    padding: 12px 14px;
  }

  .card-stats {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 8px;
    font-size: 0.82rem;
    color: var(--text-muted);
  }

  .stat-playtime {
    display: flex;
    align-items: center;
    gap: 4px;
    color: var(--text);
    font-weight: 500;
  }

  .stat-playtime svg {
    flex-shrink: 0;
    color: var(--primary);
  }

  .stat-badge {
    font-size: 0.72rem;
    color: var(--primary);
    background: rgba(117, 149, 232, 0.08);
    padding: 2px 8px;
    border-radius: 10px;
    white-space: nowrap;
    transition: background 0.2s, color 0.2s;
  }

  .game-card:not(.skeleton):hover .stat-badge {
    background: var(--primary);
    color: #fff;
  }

  /* ===== Skeleton ===== */
  .skeleton-img {
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, var(--accent) 25%, var(--border) 50%, var(--accent) 75%);
    background-size: 200% 100%;
    animation: shimmer 1.2s ease-in-out infinite;
  }

  .skeleton-line {
    height: 12px;
    border-radius: 4px;
    background: linear-gradient(90deg, var(--accent) 25%, var(--border) 50%, var(--accent) 75%);
    background-size: 200% 100%;
    animation: shimmer 1.2s ease-in-out infinite;
  }

  .skeleton-name {
    width: 75%;
    margin-bottom: 8px;
  }

  .skeleton-stat {
    width: 45%;
    height: 10px;
  }

  @keyframes shimmer {
    0% { background-position: 200% 0; }
    100% { background-position: -200% 0; }
  }

  /* ===== Counter ===== */
  .steam-counter {
    text-align: center;
    margin-top: 20px;
    color: var(--text-muted);
    font-size: 0.85rem;
  }

  /* ===== Error / Empty ===== */
  .steam-message {
    text-align: center;
    padding: 80px 20px;
    color: var(--text-muted);
  }

  .steam-message svg {
    margin-bottom: 16px;
    opacity: 0.35;
  }

  .steam-message h3 {
    font-size: 1.15rem;
    margin: 0 0 8px;
    color: var(--text);
  }

  .steam-message p {
    margin: 0;
    font-size: 0.9rem;
    line-height: 1.6;
  }

  .steam-message a {
    color: var(--primary);
    text-decoration: underline;
  }

  /* ===== Animations for cards ===== */
  .game-card {
    animation: card-enter 0.4s ease-out both;
  }

  @keyframes card-enter {
    from {
      opacity: 0;
      transform: translateY(12px) scale(0.97);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .game-card {
      animation: none;
    }
    .skeleton-img,
    .skeleton-line {
      animation: none;
    }
  }

  @media (max-width: 640px) {
    .steam-grid {
      grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
      gap: 12px;
    }
    .card-info {
      padding: 8px 10px;
    }
    .card-image-overlay .game-name {
      font-size: 0.78rem;
    }
    .card-stats {
      font-size: 0.74rem;
    }
  }
</style>

{
  isConfigured && (
    <script>
      function formatPlaytime(minutes: number): string {
        if (!minutes || minutes < 1) return '< 1 小时';
        const hours = minutes / 60;
        if (hours < 1) return `${Math.round(minutes)} 分钟`;
        if (hours < 10) return `${hours.toFixed(1)} 小时`;
        return `${Math.round(hours)} 小时`;
      }

      function gameImage(appid: number): string {
        return `https://cdn.cloudflare.steamstatic.com/steam/apps/${appid}/header.jpg`;
      }

      function steamStoreLink(appid: number): string {
        return `https://store.steampowered.com/app/${appid}`;
      }

      interface Game {
        appid: number;
        name: string;
        playtime_forever: number;
        img_icon_url: string;
        img_logo_url: string;
        has_community_visible_stats: boolean;
      }

      function renderCard(game: Game, index: number): string {
        const img = gameImage(game.appid);
        const playtime = formatPlaytime(game.playtime_forever);
        const style = `animation-delay: ${index * 0.04}s`;

        return `
          <a href="${steamStoreLink(game.appid)}" target="_blank" rel="noopener noreferrer"
             class="game-card" style="${style}">
            <div class="card-image-wrap">
              <img src="${img}" alt="${game.name}" loading="lazy"
                   onerror="this.parentElement.classList.add('img-error')" />
              <div class="card-image-overlay">
                <span class="game-name">${game.name}</span>
              </div>
            </div>
            <div class="card-info">
              <div class="card-stats">
                <span class="stat-playtime">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="10"/>
                    <polyline points="12,6 12,12 16,14"/>
                  </svg>
                  ${playtime}
                </span>
                ${game.has_community_visible_stats
                  ? '<span class="stat-badge">公开数据</span>'
                  : ''}
              </div>
            </div>
          </a>
        `;
      }

      function renderSkeleton(count: number): string {
        return Array.from({ length: count }).map(() => `
          <div class="game-card skeleton">
            <div class="card-image-wrap">
              <div class="skeleton-img"></div>
            </div>
            <div class="card-info">
              <div class="skeleton-line skeleton-name"></div>
              <div class="skeleton-line skeleton-stat"></div>
            </div>
          </div>
        `).join('');
      }

      function renderError(message: string): string {
        return `
          <div class="steam-message">
            <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" opacity="0.35">
              <circle cx="12" cy="12" r="10"/>
              <line x1="12" y1="8" x2="12" y2="12"/>
              <line x1="12" y1="16" x2="12.01" y2="16"/>
            </svg>
            <h3>${message}</h3>
            <p>请确保已创建 <code>/api/steam</code> API 路由，且 Steam API Key 配置正确</p>
          </div>
        `;
      }

      function renderEmpty(): string {
        return `
          <div class="steam-message">
            <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" opacity="0.35">
              <circle cx="12" cy="12" r="10"/>
              <path d="M8 14s1.5 2 4 2 4-2 4-2"/>
              <line x1="9" y1="9" x2="9.01" y2="9"/>
              <line x1="15" y1="9" x2="15.01" y2="9"/>
            </svg>
            <h3>未找到游戏</h3>
            <p>该 Steam 账号的库中似乎还没有游戏记录</p>
          </div>
        `;
      }

      async function loadGames(): Promise<void> {
        const grid = document.getElementById('steam-grid')!;
        const counter = document.getElementById('steam-counter')!;

        try {
          const res = await fetch('/api/steam');
          if (!res.ok) {
            const data = await res.json().catch(() => ({}));
            const msg = data?.error || `请求失败 (${res.status})`;
            grid.innerHTML = renderError(msg);
            return;
          }

          const data = await res.json();
          const games: Game[] = data.games ?? [];

          if (!games.length) {
            grid.innerHTML = renderEmpty();
            return;
          }

          counter.textContent = `共 ${games.length} 款游戏`;

          grid.innerHTML = games.map((g, i) => renderCard(g, i)).join('');
        } catch {
          grid.innerHTML = renderError('无法连接到 API');
        }
      }

      loadGames();
    </script>
  )
}
