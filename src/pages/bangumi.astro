---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../config/site';
import zh from '../i18n/zh';

if (!siteConfig.features.bangumi) {
  return Astro.redirect('/', 302);
}

const { source, bilibiliUid, bangumiUid, malUsername } = siteConfig.bangumi;

const isBilibili = source === 'bilibili' && !!bilibiliUid;
const isRemoteSource = source === 'bangumi' || source === 'mal';
const isConfigured = isBilibili || ((source === 'bangumi' && !!bangumiUid) || (source === 'mal' && !!malUsername));
---

<BaseLayout title={zh.bangumi}>
  <div class="bangumi-page">
    <h1 class="page-title">{zh.bangumi}</h1>

    {isBilibili ? (
      <>
        <p class="page-subtitle">Bilibili 追番列表</p>
        <div class="bangumi-grid" id="bangumi-grid" data-uid={bilibiliUid}>
          {/* Skeleton cards */}
          {Array.from({ length: 6 }).map(() => (
            <div class="bangumi-card skeleton">
              <div class="skeleton-cover"></div>
            </div>
          ))}
        </div>
        <div class="bangumi-error" id="bangumi-error" style="display:none">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" opacity="0.3">
            <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
          </svg>
          <p>获取追番数据失败</p>
          <span class="bangumi-retry" id="bangumi-retry">点击重试</span>
        </div>
      </>
    ) : isRemoteSource ? (
      <div class="bangumi-notice">
        <div class="notice-icon">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" opacity="0.3">
            <rect x="2" y="3" width="20" height="14" rx="2"/>
            <path d="M8 21h8M12 17v4"/>
          </svg>
        </div>
        <p class="notice-text">
          {source === 'bangumi' ? 'Bangumi.tv' : 'MyAnimeList'} 数据源需要服务端代理支持，目前暂不可用。
        </p>
        <p class="notice-suggest">
          建议使用 <strong>Bilibili</strong> 数据源：在 <code>src/config/site.ts</code> 中将 <code>bangumi.source</code> 设为 <code>'bilibili'</code>，
          并填入你的 <code>bilibiliUid</code>。
        </p>
      </div>
    ) : (
      <div class="bangumi-placeholder">
        <div class="placeholder-icon">
          <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" opacity="0.3">
            <rect x="2" y="3" width="20" height="14" rx="2"/>
            <line x1="8" y1="21" x2="16" y2="21"/>
            <line x1="12" y1="17" x2="12" y2="21"/>
          </svg>
        </div>
        <h2>追番</h2>
        <p class="placeholder-desc">展示在看的动漫、已看记录与进度</p>
        <div class="placeholder-config">
          <p>在 <code>src/config/site.ts</code> 中配置追番数据源：</p>
          <div class="config-code">
            <pre><code>bangumi: {'{\n'}
  source: 'bilibili',  // 'bilibili' | 'bangumi' | 'mal'{'\n'}
  bilibiliUid: '你的B站UID',{'\n'}
  bangumiUid: '',{'\n'}
  malUsername: '',{'\n'}
{'}'}</code></pre>
          </div>
        </div>
      </div>
    )}
  </div>
</BaseLayout>

<style>
  .bangumi-page {
    max-width: var(--content-width);
    margin: 80px auto 0;
    padding: 0 20px 60px;
  }

  .page-title {
    font-size: 2rem;
    margin: 0 0 8px;
    text-align: center;
  }

  .page-subtitle {
    text-align: center;
    color: var(--text-muted);
    font-size: 0.9rem;
    margin: 0 0 32px;
  }

  /* ===== Grid ===== */
  .bangumi-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
  }

  @media (max-width: 1100px) {
    .bangumi-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 750px) {
    .bangumi-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .bangumi-grid {
      grid-template-columns: 1fr;
    }
  }

  /* ===== Card ===== */
  .bangumi-card {
    position: relative;
    border-radius: var(--radius);
    overflow: hidden;
    aspect-ratio: 3 / 4;
    background: var(--surface);
    border: 1px solid var(--border);
    cursor: pointer;
    transition: transform 0.25s, box-shadow 0.25s, border-color 0.25s;
  }

  .bangumi-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(117, 149, 232, 0.15);
    border-color: var(--primary);
  }

  .bangumi-card .card-cover {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .bangumi-card .card-title-bar {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    padding: 16px 12px 32px;
    background: linear-gradient(to bottom, rgba(0,0,0,0.75) 0%, rgba(0,0,0,0.35) 60%, transparent 100%);
    z-index: 2;
  }

  .bangumi-card .card-title {
    color: #fff;
    font-size: 0.95rem;
    font-weight: 600;
    line-height: 1.3;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    text-shadow: 0 1px 4px rgba(0,0,0,0.6);
  }

  .bangumi-card .card-info-layer {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 24px 14px 16px;
    background: linear-gradient(to top, rgba(0,0,0,0.9) 0%, rgba(0,0,0,0.6) 50%, transparent 100%);
    z-index: 2;
    transform: translateY(100%);
    transition: transform 0.3s ease;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .bangumi-card:hover .card-info-layer {
    transform: translateY(0);
  }

  .card-progress-row {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .card-progress-bar {
    flex: 1;
    height: 4px;
    background: rgba(255,255,255,0.2);
    border-radius: 2px;
    overflow: hidden;
  }

  .card-progress-fill {
    height: 100%;
    background: var(--primary);
    border-radius: 2px;
    transition: width 0.4s ease;
  }

  .card-progress-text {
    color: #fff;
    font-size: 0.78rem;
    white-space: nowrap;
    flex-shrink: 0;
    font-weight: 500;
  }

  .card-summary {
    color: rgba(255,255,255,0.8);
    font-size: 0.8rem;
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* ===== Skeleton ===== */
  .bangumi-card.skeleton {
    pointer-events: none;
    border: 1px solid var(--border);
  }

  .skeleton-cover {
    position: absolute;
    inset: 0;
    background: var(--accent);
    animation: skeleton-pulse 1.6s ease-in-out infinite;
  }

  @keyframes skeleton-pulse {
    0%, 100% { opacity: 0.4; }
    50% { opacity: 0.8; }
  }

  /* ===== Error ===== */
  .bangumi-error {
    text-align: center;
    padding: 60px 20px;
    color: var(--text-muted);
  }

  .bangumi-error p {
    margin: 12px 0 8px;
    font-size: 1rem;
  }

  .bangumi-retry {
    color: var(--primary);
    cursor: pointer;
    font-size: 0.9rem;
    font-weight: 500;
  }

  .bangumi-retry:hover {
    text-decoration: underline;
  }

  /* ===== Remote source notice ===== */
  .bangumi-notice {
    text-align: center;
    padding: 60px 20px;
    max-width: 560px;
    margin: 0 auto;
    color: var(--text-muted);
  }

  .notice-text {
    font-size: 1rem;
    margin: 16px 0 12px;
    line-height: 1.6;
  }

  .notice-suggest {
    font-size: 0.88rem;
    line-height: 1.7;
  }

  .notice-suggest code {
    background: var(--accent);
    padding: 2px 6px;
    border-radius: 4px;
    font-size: 0.82rem;
  }

  .notice-suggest strong {
    color: var(--text);
  }

  /* ===== Placeholder ===== */
  .bangumi-placeholder {
    text-align: center;
    padding: 60px 20px 40px;
  }

  .placeholder-icon {
    margin-bottom: 16px;
    color: var(--primary);
  }

  .bangumi-placeholder h2 {
    font-size: 1.6rem;
    margin: 0 0 8px;
  }

  .placeholder-desc {
    color: var(--text-muted);
    font-size: 0.95rem;
    margin: 0 0 28px;
  }

  .placeholder-config {
    text-align: left;
    max-width: 480px;
    margin: 0 auto;
  }

  .placeholder-config p {
    font-size: 0.88rem;
    color: var(--text-muted);
    margin: 0 0 12px;
  }

  .placeholder-config code {
    background: var(--accent);
    padding: 1px 5px;
    border-radius: 3px;
    font-size: 0.82rem;
  }

  .config-code {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 16px 20px;
    overflow-x: auto;
  }

  .config-code pre {
    margin: 0;
    font-size: 0.8rem;
    line-height: 1.7;
  }

  .config-code code {
    background: none;
    padding: 0;
    color: var(--text);
  }
</style>

<script>
(function () {
  const grid = document.getElementById('bangumi-grid');
  const errorEl = document.getElementById('bangumi-error');
  const retryBtn = document.getElementById('bangumi-retry');

  if (!grid) return;

  const uid = grid.dataset.uid;
  if (!uid) return;

  const API_URL = `https://api.bilibili.com/x/space/bangumi/follow/list?type=1&follow_status=0&pn=1&ps=30&vmid=${uid}`;

  async function fetchBangumi() {
    grid.style.display = 'grid';
    errorEl.style.display = 'none';

    try {
      const resp = await fetch(API_URL, { signal: AbortSignal.timeout(12000) });
      if (!resp.ok) throw new Error(`HTTP ${resp.status}`);
      const json = await resp.json();
      if (json.code !== 0) throw new Error(json.message || 'API error');
      const list = json.data?.list;
      if (!list || list.length === 0) {
        showError('追番列表为空');
        return;
      }
      renderCards(list);
    } catch (err) {
      if (err.name !== 'AbortError') {
        showError('获取追番数据失败');
      }
    }
  }

  function renderCards(list) {
    grid.innerHTML = '';
    list.forEach((item) => {
      const card = document.createElement('a');
      card.className = 'bangumi-card';
      card.href = item.url || `https://www.bilibili.com/bangumi/media/md${item.media_id}`;
      card.target = '_blank';
      card.rel = 'noopener';

      const coverImg = document.createElement('img');
      coverImg.className = 'card-cover';
      coverImg.src = item.cover;
      coverImg.alt = item.title;
      coverImg.loading = 'lazy';

      const titleBar = document.createElement('div');
      titleBar.className = 'card-title-bar';
      const titleSpan = document.createElement('span');
      titleSpan.className = 'card-title';
      titleSpan.textContent = item.title;
      titleBar.appendChild(titleSpan);

      const infoLayer = document.createElement('div');
      infoLayer.className = 'card-info-layer';

      // Progress row
      const totalEp = parseInt(item.total, 10) || 0;
      const progressEp = parseInt(item.progress, 10) || 0;
      const pct = totalEp > 0 ? Math.min(100, Math.round((progressEp / totalEp) * 100)) : 0;

      const progressRow = document.createElement('div');
      progressRow.className = 'card-progress-row';

      const progressBar = document.createElement('div');
      progressBar.className = 'card-progress-bar';
      const progressFill = document.createElement('div');
      progressFill.className = 'card-progress-fill';
      progressFill.style.width = pct + '%';
      progressBar.appendChild(progressFill);

      const progressText = document.createElement('span');
      progressText.className = 'card-progress-text';
      progressText.textContent = totalEp > 0 ? `看到 ${progressEp}/${totalEp} 话` : (item.progress || '未观看');

      progressRow.appendChild(progressBar);
      progressRow.appendChild(progressText);
      infoLayer.appendChild(progressRow);

      // Summary
      if (item.evaluate) {
        const summary = document.createElement('p');
        summary.className = 'card-summary';
        summary.textContent = item.evaluate;
        infoLayer.appendChild(summary);
      }

      card.appendChild(coverImg);
      card.appendChild(titleBar);
      card.appendChild(infoLayer);
      grid.appendChild(card);
    });
  }

  function showError(msg) {
    grid.innerHTML = '';
    grid.style.display = 'none';
    errorEl.style.display = '';
    const p = errorEl.querySelector('p');
    if (p) p.textContent = msg;
  }

  if (retryBtn) {
    retryBtn.addEventListener('click', fetchBangumi);
  }

  fetchBangumi();
})();
</script>
