---
import BaseLayout from '../layouts/BaseLayout.astro';
import Sidebar from '../components/Sidebar.astro';
import CommitTimeline from '../components/CommitTimeline.astro';
import { siteConfig } from '../config/site';
import zh from '../i18n/zh';
import { fetchRecentCommits } from '../lib/github';
import { getSiteStats } from '../lib/stats';

const commits = await fetchRecentCommits();
const stats = await getSiteStats();
---

<BaseLayout title={zh.about} {stats}>
  <div class="about-page">
    <div class="about-main">
      <h1 class="page-title">{zh.about}</h1>

      <div class="profile-section">
        <img
          src={siteConfig.avatar}
          alt={siteConfig.author}
          class="avatar"
          width="80"
          height="80"
        />
        <div class="profile-info">
          <h2>{siteConfig.author}</h2>
          <p>{siteConfig.authorBio}</p>
        </div>
      </div>

      <CommitTimeline {commits} />
    </div>
    <Sidebar {stats} />
  </div>
</BaseLayout>

<style>
  .about-page {
    max-width: var(--content-width);
    margin: 80px auto 0;
    padding: 0 20px;
  }

  .about-main {
    min-width: 0;
  }

  .page-title {
    font-size: 2rem;
    margin: 0 0 24px;
  }

  .profile-section {
    display: flex;
    gap: 20px;
    align-items: center;
    margin-bottom: 32px;
    padding: 20px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
  }

  .avatar {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    object-fit: cover;
  }

  .profile-info h2 {
    margin: 0 0 4px;
  }

  .profile-info p {
    color: var(--text-muted);
    margin: 0;
  }

  @media (min-width: 769px) {
    .about-page {
      position: relative;
    }
    .about-page :global(.sidebar) {
      position: absolute;
      right: -260px;
      top: 0;
    }
  }
</style>
