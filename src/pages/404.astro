---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../config/site';
---

<BaseLayout title="404">
  <div class="not-found">
    <div class="nf-code">404</div>
    <h1>页面不存在</h1>
    <p>你访问的页面可能已被删除、移动，或者从未存在过。</p>
    <div class="nf-actions">
      <a href="/" class="nf-btn">返回首页</a>
      <a href="/search/" class="nf-btn secondary">搜索文章</a>
    </div>
  </div>
</BaseLayout>

<style>
  .not-found {
    max-width: var(--content-width);
    margin: 120px auto 0;
    padding: 0 20px 60px;
    text-align: center;
  }

  .nf-code {
    font-family: var(--font-mono);
    font-size: 6rem;
    font-weight: 700;
    color: var(--primary);
    opacity: 0.3;
    line-height: 1;
    margin-bottom: 16px;
  }

  .not-found h1 {
    font-size: 1.5rem;
    margin: 0 0 8px;
  }

  .not-found p {
    color: var(--text-muted);
    margin: 0 0 32px;
    font-size: 0.95rem;
  }

  .nf-actions {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .nf-btn {
    display: inline-block;
    padding: 10px 24px;
    border-radius: 24px;
    font-size: 0.9rem;
    font-weight: 600;
    color: #fff;
    background: var(--primary);
    text-decoration: none;
    transition: background 0.2s, transform 0.2s;
  }
  .nf-btn:hover {
    background: var(--primary-hover);
    transform: translateY(-1px);
  }

  .nf-btn.secondary {
    background: var(--accent);
    color: var(--text);
  }
  .nf-btn.secondary:hover {
    background: var(--border);
  }
</style>
