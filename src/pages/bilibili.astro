---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../config/site';
import zh from '../i18n/zh';

const uid = siteConfig.bilibili?.uid || '';
const hasUid = uid.length > 0;
const pageTitle = zh.bilibili;
---

<BaseLayout title={pageTitle}>
  <div class="bilibili-page" id="bilibili-root">
    {
      !hasUid ? (
        <div class="placeholder-hero">
          <div class="placeholder-icon">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" opacity="0.3">
              <rect x="2" y="3" width="20" height="14" rx="2"/>
              <polygon points="10,7 16,10 10,13" fill="currentColor" opacity="0.3"/>
              <line x1="2" y1="20" x2="22" y2="20"/>
            </svg>
          </div>
          <h1>Bilibili 收藏</h1>
          <p class="placeholder-desc">B 站收藏夹展示 — 精选视频、番剧、课程</p>
          <div class="placeholder-instructions">
            <p>请在站点配置中设置您的 Bilibili UID 以启用此功能。</p>
            <code>src/config/site.ts</code>
            <pre>{`bilibili: {\n  uid: '你的B站UID',\n}`}</pre>
          </div>
        </div>
      ) : (
        <>
          <div class="bilibili-header">
            <h1 class="bilibili-title">B站收藏</h1>
          </div>

          <!-- Folder tabs -->
          <div class="tabs-container" id="tabs-container">
            <div class="tabs-skeleton" id="tabs-skeleton">
              <span class="sk-tab"></span>
              <span class="sk-tab"></span>
              <span class="sk-tab"></span>
              <span class="sk-tab"></span>
            </div>
            <div class="tabs-wrapper" id="tabs-wrapper" style="display:none;"></div>
          </div>

          <!-- Error message -->
          <div class="error-box" id="error-box" style="display:none;">
            <p id="error-message"></p>
            <button class="retry-btn" id="retry-btn">重试</button>
          </div>

          <!-- Video grid -->
          <div class="video-grid" id="video-grid"></div>

          <!-- Pagination -->
          <div class="pagination" id="pagination" style="display:none;"></div>

          <!-- Modal -->
          <div class="modal-overlay" id="modal-overlay" style="display:none;">
            <div class="modal-backdrop" id="modal-backdrop"></div>
            <div class="modal-content">
              <button class="modal-close" id="modal-close" aria-label="关闭">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                  <line x1="18" y1="6" x2="6" y2="18"/>
                  <line x1="6" y1="6" x2="18" y2="18"/>
                </svg>
              </button>
              <div class="modal-player" id="modal-player"></div>
            </div>
          </div>
        </>
      )
    }
  </div>
</BaseLayout>

<script>
  import { siteConfig } from '../config/site';

  const uid = siteConfig.bilibili?.uid || '';
  if (!uid) {
    // No-op: placeholder already rendered server-side
  } else {
    interface Folder {
      id: number;
      title: string;
      media_count: number;
    }

    interface Video {
      id: number;
      title: string;
      cover: string;
      upper: { name: string };
      intro: string;
      bvid: string;
      page: number;
    }

    const API_BASE = 'https://api.bilibili.com';

    let folders: Folder[] = [];
    let activeFolderId: number | null = null;
    let currentPage = 1;
    const PAGE_SIZE = 20;

    // DOM refs
    const tabsSkeleton = document.getElementById('tabs-skeleton')!;
    const tabsWrapper = document.getElementById('tabs-wrapper')!;
    const videoGrid = document.getElementById('video-grid')!;
    const pagination = document.getElementById('pagination')!;
    const errorBox = document.getElementById('error-box')!;
    const errorMessage = document.getElementById('error-message')!;
    const retryBtn = document.getElementById('retry-btn')!;
    const modalOverlay = document.getElementById('modal-overlay')!;
    const modalBackdrop = document.getElementById('modal-backdrop')!;
    const modalPlayer = document.getElementById('modal-player')!;
    const modalClose = document.getElementById('modal-close')!;

    function showError(msg: string) {
      errorMessage.textContent = msg;
      errorBox.style.display = 'flex';
      tabsSkeleton.style.display = 'none';
      tabsWrapper.style.display = 'none';
      videoGrid.innerHTML = '';
      pagination.style.display = 'none';
    }

    function hideError() {
      errorBox.style.display = 'none';
    }

    function showTabsSkeleton() {
      tabsSkeleton.style.display = 'flex';
      tabsWrapper.style.display = 'none';
    }

    function hideTabsSkeleton() {
      tabsSkeleton.style.display = 'none';
      tabsWrapper.style.display = 'flex';
    }

    function renderSkeletonCards(count = 9) {
      let html = '';
      for (let i = 0; i < count; i++) {
        html += `
          <div class="video-card skeleton">
            <div class="card-thumb sk-thumb"></div>
            <div class="card-body">
              <div class="sk-line sk-line-title"></div>
              <div class="sk-line sk-line-short"></div>
            </div>
          </div>`;
      }
      videoGrid.innerHTML = html;
    }

    async function fetchFolders() {
      showTabsSkeleton();
      hideError();
      videoGrid.innerHTML = '';
      pagination.style.display = 'none';

      try {
        const res = await fetch(`${API_BASE}/x/v3/fav/folder/created/list-all?up_mid=${uid}`);
        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        const json = await res.json();
        if (json.code !== 0) throw new Error(json.message || 'API 返回错误');
        folders = json.data?.list || [];
        if (folders.length === 0) {
          showError('暂无收藏夹数据');
          return;
        }
        renderTabs();
        // Auto-select first folder
        selectFolder(folders[0].id);
      } catch (err: any) {
        showError(err.message || '获取收藏夹列表失败');
      }
    }

    function renderTabs() {
      hideTabsSkeleton();
      let html = '';
      for (const f of folders) {
        html += `
          <button class="tab-btn" data-folder-id="${f.id}">
            ${escapeHtml(f.title)}
            <span class="tab-badge">${f.media_count}</span>
          </button>`;
      }
      tabsWrapper.innerHTML = html;

      // Bind tab clicks
      tabsWrapper.querySelectorAll('.tab-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          const fid = Number((btn as HTMLElement).dataset.folderId);
          selectFolder(fid);
        });
      });
    }

    function selectFolder(folderId: number) {
      activeFolderId = folderId;
      currentPage = 1;
      // Update active tab style
      tabsWrapper.querySelectorAll('.tab-btn').forEach(btn => {
        const fid = Number((btn as HTMLElement).dataset.folderId);
        btn.classList.toggle('active', fid === folderId);
      });
      fetchVideos(folderId, currentPage);
    }

    async function fetchVideos(folderId: number, page: number) {
      renderSkeletonCards(9);
      hideError();
      pagination.style.display = 'none';

      try {
        const res = await fetch(
          `${API_BASE}/x/v3/fav/resource/list?media_id=${folderId}&pn=${page}&ps=${PAGE_SIZE}`
        );
        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        const json = await res.json();
        if (json.code !== 0) throw new Error(json.message || 'API 返回错误');
        const medias: Video[] = json.data?.medias || [];
        const total = json.data?.has_more ? (page * PAGE_SIZE + 1) : page * PAGE_SIZE;

        if (medias.length === 0) {
          videoGrid.innerHTML = '<div class="empty-state">该收藏夹暂无内容</div>';
          pagination.style.display = 'none';
          return;
        }

        renderVideoCards(medias);
        renderPagination(page, json.data?.has_more ?? false);
      } catch (err: any) {
        showError(err.message || '获取视频列表失败');
      }
    }

    function renderVideoCards(medias: Video[]) {
      if (medias.length === 0) {
        videoGrid.innerHTML = '<div class="empty-state">该收藏夹暂无内容</div>';
        return;
      }
      let html = '';
      for (const v of medias) {
        html += `
          <div class="video-card" data-bvid="${escapeHtml(v.bvid)}" data-page="${v.page || 1}">
            <div class="card-thumb">
              <img src="${escapeHtml(v.cover)}" alt="${escapeHtml(v.title)}" loading="lazy" />
              <div class="card-play-btn">
                <svg width="48" height="48" viewBox="0 0 24 24" fill="rgba(255,255,255,0.92)" stroke="none">
                  <polygon points="8,5 19,12 8,19"/>
                </svg>
              </div>
              <div class="card-title-overlay">${escapeHtml(v.title)}</div>
            </div>
            <div class="card-body">
              <div class="card-uploader">${escapeHtml(v.upper.name)}</div>
              <div class="card-desc">${escapeHtml(v.intro || '暂无简介')}</div>
            </div>
          </div>`;
      }
      videoGrid.innerHTML = html;

      // Bind card clicks for modal
      videoGrid.querySelectorAll('.video-card').forEach(card => {
        card.addEventListener('click', () => {
          const el = card as HTMLElement;
          const bvid = el.dataset.bvid || '';
          const page = Number(el.dataset.page) || 1;
          openModal(bvid, page);
        });
      });
    }

    function renderPagination(page: number, hasMore: boolean) {
      let html = '';
      const showPrev = page > 1;
      html += `<button class="page-btn" data-page="${page - 1}" ${showPrev ? '' : 'disabled'}>上一页</button>`;
      html += `<span class="page-info">第 ${page} 页</span>`;
      html += `<button class="page-btn" data-page="${page + 1}" ${hasMore ? '' : 'disabled'}>下一页</button>`;
      pagination.innerHTML = html;
      pagination.style.display = 'flex';

      pagination.querySelectorAll('.page-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          const el = btn as HTMLElement;
          if (el.disabled) return;
          const p = Number(el.dataset.page);
          if (p > 0 && activeFolderId !== null) {
            currentPage = p;
            fetchVideos(activeFolderId, p);
            videoGrid.scrollIntoView({ behavior: 'smooth', block: 'start' });
          }
        });
      });
    }

    function openModal(bvid: string, page: number) {
      modalPlayer.innerHTML = `
        <iframe
          src="//player.bilibili.com/player.html?bvid=${bvid}&page=${page}&autoplay=1"
          frameborder="0"
          allowfullscreen
          allow="autoplay; encrypted-media"
          class="player-iframe">
        </iframe>`;
      modalOverlay.style.display = 'flex';
      document.body.style.overflow = 'hidden';
    }

    function closeModal() {
      modalOverlay.style.display = 'none';
      modalPlayer.innerHTML = '';
      document.body.style.overflow = '';
    }

    modalClose.addEventListener('click', closeModal);
    modalBackdrop.addEventListener('click', closeModal);
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && modalOverlay.style.display === 'flex') {
        closeModal();
      }
    });

    retryBtn.addEventListener('click', () => {
      if (activeFolderId !== null) {
        fetchVideos(activeFolderId, currentPage);
      } else {
        fetchFolders();
      }
    });

    function escapeHtml(str: string): string {
      const div = document.createElement('div');
      div.textContent = str;
      return div.innerHTML;
    }

    // Kick off
    fetchFolders();
  }
</script>

<style>
  /* ============ Page Layout ============ */
  .bilibili-page {
    max-width: var(--content-width);
    margin: calc(var(--nav-height) + 32px) auto 0;
    padding: 0 20px 60px;
    min-height: 60vh;
  }

  .bilibili-header {
    margin-bottom: 24px;
  }

  .bilibili-title {
    font-size: 1.75rem;
    font-weight: 700;
    margin: 0;
    color: var(--text);
  }

  /* ============ Placeholder (no uid) ============ */
  .placeholder-hero {
    text-align: center;
    padding: 80px 20px 40px;
  }

  .placeholder-icon {
    margin-bottom: 20px;
    color: var(--primary);
  }

  .placeholder-hero h1 {
    font-size: 2rem;
    margin: 0 0 8px;
    font-family: var(--font-serif);
  }

  .placeholder-desc {
    color: var(--text-muted);
    font-size: 1rem;
    margin: 0 0 28px;
    line-height: 1.6;
  }

  .placeholder-instructions {
    text-align: left;
    max-width: 480px;
    margin: 0 auto;
    color: var(--text-muted);
    font-size: 0.9rem;
    line-height: 1.8;
  }

  .placeholder-instructions code {
    background: var(--accent);
    padding: 2px 8px;
    border-radius: 4px;
    font-size: 0.85rem;
    color: var(--text);
  }

  .placeholder-instructions pre {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 16px 20px;
    margin-top: 8px;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--primary);
    overflow-x: auto;
  }

  /* ============ Tabs ============ */
  .tabs-container {
    margin-bottom: 24px;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }

  .tabs-container::-webkit-scrollbar {
    display: none;
  }

  .tabs-skeleton {
    display: flex;
    gap: 8px;
    padding: 4px 0;
  }

  .sk-tab {
    width: 100px;
    height: 36px;
    border-radius: 18px;
    background: var(--accent);
    animation: skeleton-pulse 1.5s ease-in-out infinite;
    flex-shrink: 0;
  }

  .tabs-wrapper {
    display: flex;
    gap: 8px;
    flex-wrap: nowrap;
    padding: 4px 0;
  }

  .tab-btn {
    flex-shrink: 0;
    padding: 8px 18px;
    border-radius: 18px;
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--text-muted);
    font-size: 0.88rem;
    cursor: pointer;
    transition: all 0.25s ease;
    font-family: var(--font-sans);
    white-space: nowrap;
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .tab-btn:hover {
    color: var(--primary);
    border-color: var(--primary);
  }

  .tab-btn.active {
    background: var(--primary);
    color: #fff;
    border-color: var(--primary);
  }

  .tab-btn.active .tab-badge {
    background: rgba(255, 255, 255, 0.25);
    color: #fff;
  }

  .tab-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 20px;
    height: 18px;
    border-radius: 9px;
    background: var(--accent);
    color: var(--text-muted);
    font-size: 0.72rem;
    padding: 0 6px;
    transition: all 0.25s ease;
  }

  /* ============ Error ============ */
  .error-box {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    padding: 48px 20px;
    text-align: center;
    color: var(--text-muted);
  }

  .error-box p {
    margin: 0;
    font-size: 0.95rem;
  }

  .retry-btn {
    padding: 8px 24px;
    border-radius: 20px;
    border: 1px solid var(--primary);
    background: var(--surface);
    color: var(--primary);
    cursor: pointer;
    font-size: 0.88rem;
    font-family: var(--font-sans);
    transition: all 0.2s ease;
  }

  .retry-btn:hover {
    background: var(--primary);
    color: #fff;
  }

  /* ============ Video Grid ============ */
  .video-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  @media (max-width: 960px) {
    .video-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .video-grid {
      grid-template-columns: 1fr;
    }
  }

  /* ============ Video Card ============ */
  .video-card {
    background: var(--surface);
    border-radius: var(--radius);
    overflow: hidden;
    border: 1px solid var(--border);
    cursor: pointer;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }

  .video-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
  }

  .video-card:hover .card-thumb img {
    transform: scale(1.06);
  }

  .video-card:hover .card-play-btn {
    opacity: 1;
    transform: translate(-50%, -50%) scale(1);
  }

  .card-thumb {
    position: relative;
    padding-top: 56.25%; /* 16:9 */
    overflow: hidden;
    background: var(--accent);
  }

  .card-thumb img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.35s ease;
  }

  .card-play-btn {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%) scale(0.8);
    opacity: 0;
    transition: all 0.25s ease;
    pointer-events: none;
    z-index: 2;
    filter: drop-shadow(0 2px 6px rgba(0,0,0,0.4));
  }

  .card-title-overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    padding: 8px 12px;
    background: linear-gradient(to bottom, rgba(0,0,0,0.55) 0%, rgba(0,0,0,0) 100%);
    color: #fff;
    font-size: 0.85rem;
    line-height: 1.4;
    font-weight: 600;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    z-index: 1;
  }

  .card-body {
    padding: 10px 12px 12px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .card-uploader {
    font-size: 0.78rem;
    color: var(--text-muted);
    text-align: right;
  }

  .card-desc {
    font-size: 0.8rem;
    color: var(--text-muted);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* ============ Skeleton Card ============ */
  .video-card.skeleton {
    pointer-events: none;
    cursor: default;
  }

  .video-card.skeleton:hover {
    transform: none;
    box-shadow: none;
  }

  .sk-thumb {
    padding-top: 56.25%;
    background: var(--accent);
    animation: skeleton-pulse 1.5s ease-in-out infinite;
  }

  .sk-line {
    height: 14px;
    border-radius: 4px;
    background: var(--accent);
    animation: skeleton-pulse 1.5s ease-in-out infinite;
  }

  .sk-line-title {
    width: 75%;
  }

  .sk-line-short {
    width: 45%;
  }

  @keyframes skeleton-pulse {
    0%, 100% { opacity: 0.4; }
    50% { opacity: 0.8; }
  }

  /* ============ Empty State ============ */
  .empty-state {
    grid-column: 1 / -1;
    text-align: center;
    padding: 60px 20px;
    color: var(--text-muted);
    font-size: 0.95rem;
  }

  /* ============ Pagination ============ */
  .pagination {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    margin-top: 32px;
    padding: 8px 0;
  }

  .page-btn {
    padding: 8px 20px;
    border-radius: 20px;
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--text);
    cursor: pointer;
    font-size: 0.88rem;
    font-family: var(--font-sans);
    transition: all 0.2s ease;
  }

  .page-btn:hover:not(:disabled) {
    border-color: var(--primary);
    color: var(--primary);
  }

  .page-btn:disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }

  .page-info {
    font-size: 0.88rem;
    color: var(--text-muted);
  }

  /* ============ Modal ============ */
  .modal-overlay {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    animation: modal-fade-in 0.2s ease;
  }

  .modal-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.7);
    backdrop-filter: blur(4px);
  }

  .modal-content {
    position: relative;
    width: 90vw;
    max-width: 900px;
    aspect-ratio: 16 / 9;
    max-height: 85vh;
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: 0 16px 48px rgba(0, 0, 0, 0.4);
    animation: modal-scale-in 0.25s ease;
  }

  .modal-close {
    position: absolute;
    top: 12px;
    right: 12px;
    z-index: 10;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: none;
    background: rgba(0, 0, 0, 0.5);
    color: #fff;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s ease;
  }

  .modal-close:hover {
    background: rgba(0, 0, 0, 0.75);
  }

  .modal-player {
    width: 100%;
    height: 100%;
  }

  .player-iframe {
    width: 100%;
    height: 100%;
    border: none;
  }

  @keyframes modal-fade-in {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  @keyframes modal-scale-in {
    from { opacity: 0; transform: scale(0.92); }
    to { opacity: 1; transform: scale(1); }
  }

  /* ============ Responsive Modal ============ */
  @media (max-width: 600px) {
    .modal-content {
      width: 100vw;
      height: auto;
      aspect-ratio: 16 / 9;
      border-radius: 0;
    }

    .modal-close {
      top: 8px;
      right: 8px;
      width: 32px;
      height: 32px;
    }
  }

  /* ============ Reduced Motion ============ */
  @media (prefers-reduced-motion: reduce) {
    .video-card,
    .video-card:hover,
    .card-thumb img,
    .video-card:hover .card-thumb img,
    .card-play-btn,
    .video-card:hover .card-play-btn,
    .tab-btn,
    .modal-overlay,
    .modal-content {
      transition: none !important;
      animation: none !important;
    }
  }
</style>
