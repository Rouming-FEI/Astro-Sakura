---
import zh from '../i18n/zh';

interface Props {
  title: string;
  slug: string;
  date: string;
  updated?: string;
  excerpt?: string;
  thumbnail?: string;
  category?: string;
  tags?: string[];
  pinned?: boolean;
  wordCount?: number;
}

const { title, slug, date, updated, excerpt = '', thumbnail, category, tags = [], pinned, wordCount = 0 } = Astro.props;
const dateObj = new Date(date);
const formattedDate = dateObj.toLocaleDateString('zh-CN');
const dateYear = dateObj.getFullYear().toString();
const hasUpdate = updated && updated !== date;
const updatedStr = hasUpdate ? new Date(updated!).toLocaleDateString('zh-CN') : '';
const wordCountStr = wordCount > 1000 ? `${(wordCount / 1000).toFixed(1)}k字` : `${wordCount}字`;
---

<article class="post-card" class:list={{ pinned }}>
  {thumbnail && (
    <a href={`/posts/${slug}/`} class="post-thumb">
      <img src={thumbnail} alt={title} loading="lazy" decoding="async" />
    </a>
  )}
  <div class="post-body">
    <h2 class="post-title">
      {pinned && <span class="pinned-badge">&#x1F4CC; {zh.pinned}</span>}
      <a href={`/posts/${slug}/`}>{title}</a>
    </h2>
    <div class="post-meta">
      <a href={`/categories/?year=${dateYear}`} class="post-date-link" title="按年份浏览">
        <time datetime={date}>{formattedDate}</time>
      </a>
      {hasUpdate && <span class="post-updated" title={`更新于 ${updatedStr}`}>更新</span>}
      <span class="meta-sep">&middot;</span>
      <span class="post-wordcount">{wordCountStr}</span>
      {category && (
        <>
          <span class="meta-sep">&middot;</span>
          <a href={`/categories/?category=${encodeURIComponent(category)}`} class="post-category">{category}</a>
        </>
      )}
    </div>
    {excerpt && <p class="post-excerpt">{excerpt}</p>}
    {tags.length > 0 && (
      <div class="post-tags">
        {tags.map(tag => <a href={`/categories/?tag=${encodeURIComponent(tag)}`} class="tag"># {tag}</a>)}
      </div>
    )}
  </div>
</article>

<style>
  .post-card {
    display: flex;
    gap: 20px;
    padding: 20px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    margin-bottom: 14px;
    transition: transform 0.25s, box-shadow 0.25s, border-color 0.25s;
    position: relative;
    overflow: hidden;
  }
  .post-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--primary), transparent);
    opacity: 0;
    transition: opacity 0.25s;
  }
  .post-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 24px rgba(117, 149, 232, 0.15);
    border-color: var(--primary);
  }
  .post-card:hover::before {
    opacity: 1;
  }
  .post-card.pinned {
    border-color: rgba(117, 149, 232, 0.3);
  }
  .post-card.pinned::before {
    opacity: 1;
    background: linear-gradient(90deg, var(--primary), #a594e8, transparent);
  }

  .post-thumb {
    flex-shrink: 0;
    width: 140px;
    height: 96px;
    overflow: hidden;
    border-radius: 8px;
  }
  .post-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s;
  }
  .post-card:hover .post-thumb img {
    transform: scale(1.08);
  }

  .post-body {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .post-title {
    font-family: var(--font-serif);
    font-size: 1.1rem;
    margin: 0 0 6px;
    line-height: 1.4;
  }
  .post-title a {
    color: var(--text);
    transition: color 0.2s;
    background: linear-gradient(90deg, var(--primary), transparent 80%) left bottom / 0% 1px no-repeat;
    padding-bottom: 2px;
  }
  .post-title a:hover {
    color: var(--primary);
    background-size: 100% 1px;
  }

  .pinned-badge {
    font-size: 0.7rem;
    color: var(--primary);
    background: rgba(117, 149, 232, 0.1);
    padding: 1px 8px;
    border-radius: 10px;
    margin-right: 8px;
    font-weight: 600;
    vertical-align: middle;
  }

  .post-date-link {
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.2s;
  }
  .post-date-link:hover {
    color: var(--primary);
  }

  .post-meta {
    font-size: 0.75rem;
    color: var(--text-muted);
    display: flex;
    gap: 6px;
    align-items: center;
    flex-wrap: wrap;
  }

  .meta-sep {
    opacity: 0.4;
    font-weight: 300;
  }

  .post-updated {
    font-size: 0.65rem;
    color: var(--primary);
    background: rgba(117, 149, 232, 0.15);
    padding: 1px 6px;
    border-radius: 6px;
    font-weight: 600;
  }

  .post-wordcount {
    font-size: 0.72rem;
    color: var(--text-muted);
    opacity: 0.8;
  }

  .post-category {
    font-size: 0.7rem;
    color: var(--primary);
    background: rgba(117, 149, 232, 0.1);
    padding: 2px 10px;
    border-radius: 10px;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.2s;
  }
  .post-category:hover {
    background: rgba(117, 149, 232, 0.2);
  }

  .post-excerpt {
    font-size: 0.875rem;
    color: var(--text-muted);
    margin: 10px 0 0;
    line-height: 1.7;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post-tags {
    display: flex;
    gap: 4px;
    margin-top: 12px;
    flex-wrap: wrap;
  }

  .tag {
    font-size: 0.68rem;
    color: var(--text-muted);
    padding: 1px 6px;
    border-radius: 4px;
    opacity: 0.75;
    text-decoration: none;
    transition: opacity 0.2s, color 0.2s;
  }
  .tag:hover {
    opacity: 1;
    color: var(--primary);
  }

  @media (max-width: 500px) {
    .post-card {
      flex-direction: column;
    }
    .post-thumb {
      width: 100%;
      height: 160px;
    }
  }
</style>
