---
import ThemeToggle from './ThemeToggle.astro';
import { siteConfig } from '../config/site';
import zh from '../i18n/zh';

const currentPath = Astro.url.pathname;

const pages = [
  { href: '/', label: zh.home },
  { href: '/categories/', label: zh.categories },
  { href: '/archive/', label: zh.archive },
  { href: '/about/', label: zh.about },
  { href: '/links/', label: zh.links },
];

const isHome = currentPath === '/';

const isActive = (href: string) => {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
};
---

<header class="site-nav" class:list={{ transparent: isHome }}>
  <div class="nav-inner">
    <a href="/" class="logo">{siteConfig.title}</a>

    <nav class="nav-links" aria-label="Main navigation">
      {pages.map(p => (
        <a
          href={p.href}
          class="nav-link"
          class:list={{ active: isActive(p.href) }}
        >
          {p.label}
        </a>
      ))}
    </nav>

    <div class="nav-actions">
      <a href="/search/" class="search-trigger" aria-label={zh.search}>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
          <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
        </svg>
      </a>

      <ThemeToggle />

      <button class="menu-btn" aria-label="Menu" aria-expanded="false">
        <svg class="menu-icon-open" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
          <line x1="3" y1="5" x2="21" y2="5"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="19" x2="21" y2="19"/>
        </svg>
        <svg class="menu-icon-close" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
          <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>
  </div>

  <div class="mobile-menu" id="mobile-menu">
    {pages.map(p => (
      <a
        href={p.href}
        class="mobile-link"
        class:list={{ active: isActive(p.href) }}
      >
        {p.label}
      </a>
    ))}
    <a href="/search/" class="mobile-link">&#x1F50D; {zh.search}</a>
  </div>
</header>

<script is:inline>
  (function() {
    var nav = document.querySelector('.site-nav');
    var btn = document.querySelector('.menu-btn');
    var menu = document.getElementById('mobile-menu');

    // Scroll behavior for transparent nav
    if (nav && nav.classList.contains('transparent')) {
      function update() {
        nav.classList.toggle('scrolled', window.scrollY > 10);
      }
      window.addEventListener('scroll', update, { passive: true });
      update();
    }

    // Mobile menu toggle
    if (btn && menu) {
      btn.addEventListener('click', function() {
        var open = menu.classList.toggle('open');
        btn.setAttribute('aria-expanded', String(open));
      });

      // Close on link click
      menu.querySelectorAll('a').forEach(function(a) {
        a.addEventListener('click', function() {
          menu.classList.remove('open');
          btn.setAttribute('aria-expanded', 'false');
        });
      });

      // Close on click outside
      document.addEventListener('click', function(e) {
        if (!nav.contains(e.target)) {
          menu.classList.remove('open');
          btn.setAttribute('aria-expanded', 'false');
        }
      });

      // Close on resize to desktop
      window.addEventListener('resize', function() {
        if (window.innerWidth > 640) {
          menu.classList.remove('open');
          btn.setAttribute('aria-expanded', 'false');
        }
      });
    }
  })();
</script>

<style>
  .site-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    height: var(--nav-height);
    background: var(--surface);
    border-bottom: 1px solid var(--border);
    transition: background-color 0.3s, border-color 0.3s;
  }

  .site-nav.transparent:not(.scrolled) {
    background: transparent;
    border-bottom-color: transparent;
  }

  .site-nav.transparent:not(.scrolled) .nav-link,
  .site-nav.transparent:not(.scrolled) .logo,
  .site-nav.transparent:not(.scrolled) .search-trigger,
  .site-nav.transparent:not(.scrolled) :global(#theme-toggle),
  .site-nav.transparent:not(.scrolled) .menu-btn {
    color: #fff;
    text-shadow: 0 1px 3px rgba(0,0,0,0.3);
  }
  .site-nav.transparent:not(.scrolled) .search-trigger,
  .site-nav.transparent:not(.scrolled) :global(#theme-toggle) {
    opacity: 1;
  }

  .nav-inner {
    max-width: calc(var(--content-width) + 200px);
    margin: 0 auto;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 20px;
  }

  .logo {
    font-family: var(--font-serif);
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--text);
    text-decoration: none;
  }

  .nav-links {
    display: flex;
    gap: 24px;
  }

  .nav-link {
    font-size: 0.9rem;
    color: var(--text-muted);
    transition: color 0.2s;
  }
  .nav-link:hover,
  .nav-link.active {
    color: var(--primary);
  }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .search-trigger {
    color: var(--text);
    padding: 6px;
    display: flex;
    opacity: 0.7;
    transition: opacity 0.2s;
  }
  .search-trigger:hover {
    opacity: 1;
  }

  .menu-btn {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 6px;
    color: var(--text);
    opacity: 0.7;
    transition: opacity 0.2s;
  }
  .menu-btn:hover {
    opacity: 1;
  }
  .menu-icon-close { display: none; }
  .menu-btn[aria-expanded="true"] .menu-icon-open { display: none; }
  .menu-btn[aria-expanded="true"] .menu-icon-close { display: block; }

  .mobile-menu {
    display: none;
    position: fixed;
    top: var(--nav-height);
    left: 0;
    right: 0;
    background: var(--surface);
    border-bottom: 1px solid var(--border);
    padding: 8px 20px 16px;
    flex-direction: column;
    gap: 2px;
    z-index: 99;
    box-shadow: 0 8px 24px rgba(0,0,0,0.08);
  }
  .mobile-menu.open {
    display: flex;
  }

  .mobile-link {
    font-size: 0.95rem;
    color: var(--text-muted);
    padding: 10px 0;
    text-decoration: none;
    transition: color 0.2s;
  }
  .mobile-link:hover,
  .mobile-link.active {
    color: var(--primary);
  }
  .mobile-link + .mobile-link {
    border-top: 1px solid var(--border);
  }

  @media (max-width: 640px) {
    .nav-links { display: none; }
    .menu-btn { display: flex; }
  }

  @media (min-width: 641px) {
    .mobile-menu.open { display: none; }
  }
</style>
