{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "date": {
      "type": "string"
    },
    "updated": {
      "type": "string"
    },
    "pinned": {
      "default": false,
      "type": "boolean"
    },
    "category": {
      "type": "string"
    },
    "tags": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "excerpt": {
      "type": "string"
    },
    "thumbnail": {
      "type": "string"
    },
    "lang": {
      "default": "zh",
      "type": "string",
      "enum": [
        "zh",
        "ja",
        "fr"
      ]
    },
    "draft": {
      "default": false,
      "type": "boolean"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "date"
  ]
}